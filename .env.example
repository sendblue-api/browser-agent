# browser-agent configuration
# Copy this file to .env and fill in the values you need.
# All variables are optional — defaults are shown in comments.

# Port the HTTP server listens on.
# Default: 9229
# BROWSER_PORT=9229

# Base URL of the target application.
# All relative paths in POST /goto are resolved against this.
# Default: http://localhost:3000
# BROWSER_BASE_URL=http://localhost:3000

# Path to navigate to on startup.
# Default: /
# BROWSER_START_PATH=/

# Path to a Playwright storage state JSON file (cookies + localStorage).
# Required only for apps that need authentication.
# Generate with: npx playwright codegen --save-storage=auth.json <base-url>
# Default: (none — browser starts unauthenticated)
# BROWSER_AUTH_STATE=./auth.json

# Run Chromium in headless mode (no visible window).
# Set to "true" for CI/CD environments.
# Default: false
# BROWSER_HEADLESS=false

# Slow down Playwright operations by this many milliseconds.
# Useful for debugging — set to 0 for maximum speed.
# Default: 30
# BROWSER_SLOW_MO=30

# Viewport width in pixels.
# Default: 1440
# BROWSER_VIEWPORT_W=1440

# Viewport height in pixels.
# Default: 900
# BROWSER_VIEWPORT_H=900

# Directory where screenshots are saved.
# Each screenshot gets a timestamped filename (screenshot-<ISO>.png).
# Default: <os.tmpdir()>/browser-agent-screenshots
# BROWSER_SCREENSHOT_DIR=/tmp/browser-agent-screenshots
